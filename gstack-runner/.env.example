PORT=3015
GSTACK_RUNNER_ROOT=/var/lib/lite-annotate-gstack-runner
GSTACK_RUNNER_TOKEN=replace-with-lite-to-runner-secret
LITE_ANNOTATE_CALLBACK_TOKEN=replace-with-runner-to-lite-secret
LITE_ANNOTATE_CALLBACK_URL=https://lite-annotate-production.up.railway.app/internal/gstack-callback
GSTACK_REPO_ALLOWLIST=ibrolord/lite-annotate-demo
GITHUB_READ_TOKEN=
GITHUB_TOKEN=
CLAUDE_BIN=claude
CLAUDE_MAX_TURNS=8
GSTACK_JOB_TIMEOUT_MS=900000
GSTACK_KEEP_WORKDIR=0
